	},
	"peerDependenciesMeta": {
		"@zextras/carbonio-design-system": {
			"optional": true
		},
		"@zextras/carbonio-ui-preview": {
			"optional": true
		},
		"lodash": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"react-dom": {
