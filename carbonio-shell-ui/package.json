	},
	"sdk": {
		"svgr": true
	},
	"browserslist": [
		">1%",
		"last 3 version",
		"Firefox ESR",
		"not dead"
	],
	"carbonio": {
		"name": "carbonio-shell-ui",
		"translations_repository": "git@github.com:Zextras/carbonio-shell-ui-i18n.git",
		"type": "shell",
		"priority": -1,
		"display": "Shell",
		"icon": "CubeOutline"
	},
	"config": {
		"translations_repository": "git@github.com:Zextras/carbonio-shell-ui-i18n.git"
	}
}
