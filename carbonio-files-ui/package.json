{
	"name": "carbonio-files-ui",
	"version": "2.17.0",
	"description": "Files module",
	"main": "src/app.tsx",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": "v22",
		"pnpm": ">=10"
	},
	"scripts": {
		"bump-version": "semantic-release",
		"build": "sdk build",
		"start": "sdk watch",
		"deploy": "sdk install",
		"deploy:local": "sdk deploy --container ${CONTAINER:-carbonio-advanced-carbonio-composed-ui-1}",
		"watch:local": "sdk watch -h ${HOST:-localhost}",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"prepare": "is-ci || husky",
		"type-check": "tsc --noEmit",
		"type-check:watch": "pnpm run type-check --watch",
		"lint": "eslint --ext .js,.jsx,.ts,.tsx,.graphql --resolve-plugins-relative-to node_modules/@zextras/carbonio-ui-configs src",
		"generate": "graphql-codegen",
		"build:dev": "sdk build --dev --pkgRel $(date +%s)",
		"update-zextras-dependencies": "git checkout -b update-zextras-deps/$(date '+%Y-%m-%d') && ncu @zextras/carbonio-design-system @zextras/carbonio-shell-ui @zextras/carbonio-ui-preview -u && pnpm install"
	},
	"keywords": [],
	"author": "",
	"license": "AGPL-3.0-only",
	"devDependencies": {
		"@babel/core": "7.29.0",
