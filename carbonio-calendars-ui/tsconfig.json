{
	"extends": "@zextras/carbonio-ui-configs/rules/tsconfig.type-check.json",
	"compilerOptions": {
		"noUncheckedIndexedAccess": false,
		"baseUrl": "./src",
		"types": ["vitest/globals"],
		"paths": {
			"@test-mocks/*": ["../__mocks__/*"],
			"@test-utils/*": ["__test__/mocks/*"],
			"@test-setup": ["__test__/test-setup.tsx"],
			"@jest-setup": ["__test__/vitest-setup.tsx"]
		}
	},
	"include": ["**/*"],
	"exclude": ["./node_modules/*", "./dist/*"]
}
