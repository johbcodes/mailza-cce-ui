{
	"name": "carbonio-login-ui",
	"version": "0.11.3",
	"description": "Zextras authentication App",
	"main": "src/index.html",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": "v22",
		"pnpm": ">=10"
	},
	"scripts": {
		"bump-version": "semantic-release",
		"release": "standard-version",
		"type-check": "tsc --noEmit",
		"type-check:watch": "pnpm run type-check -- --watch",
		"test": "vitest run",
		"lint": "eslint --ext .js,.jsx,.ts,.tsx --resolve-plugins-relative-to node_modules/@zextras/carbonio-ui-configs src",
		"prepare": "is-ci || husky",
		"start": "webpack serve --mode='production'",
		"start-dev": "webpack serve --mode='development'",
		"build": "webpack",
		"build:dev": "webpack --mode=development",
		"test:watch": "vitest",
		"pull-translations": "git subtree pull -P translations git@github.com:Zextras/carbonio-login-ui-i18n.git master --squash",
		"push-translations": "git subtree push -P translations git@github.com:Zextras/carbonio-login-ui-i18n.git"
	},
	"author": "",
	"license": "ISC",
	"devDependencies": {
