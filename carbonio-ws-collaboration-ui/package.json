		"@zextras/carbonio-shell-ui": "^14.0.0",
		"@zextras/carbonio-ui-preview": "^4.0.1",
		"@zextras/carbonio-ui-soap-lib": "^1.0.4",
		"emoji-mart": "5.6.0",
		"i18next": "^22.5.1",
		"immer": "^10.0.3",
