		"@zextras/carbonio-ui-soap-lib": "1.3.0",
		"emoji-mart": "5.6.0",
		"i18next": "22.5.1",
		"immer": "11.1.8",
		"jsdom": "27.4.0",
		"lodash": "4.18.1",
		"moment": "2.30.1",
		"moment-timezone": "0.6.2",
		"polished": "4.3.1",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-i18next": "12.3.1",
		"react-router-dom": "6.29.0",
		"semver": "7.8.1",
		"strophe.js": "1.6.2",
		"use-sync-external-store": "1.6.0",
		"uuid": "14.0.0",
		"zustand": "5.0.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"core-js",
			"esbuild",
			"protobufjs",
			"unrs-resolver"
		]
	},
	"carbonio": {
		"name": "carbonio-ws-collaboration-ui",
		"display": "Chats",
		"priority": 404,
		"attrKey": "carbonioFeatureWscEnabled",
		"type": "carbonio"
	},
	"engines": {
		"node": "v22"
	}
