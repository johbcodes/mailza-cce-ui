# ESLint plugins are bundled inside @zextras/carbonio-ui-configs and the lint
# script uses --resolve-plugins-relative-to to point ESLint at that package.
# ESLint resolves plugins from that location but also expects them at root
# node_modules. pnpm does not hoist transitive deps by default, so without
# this pattern the plugins are invisible to ESLint and the lint script fails.
# This workaround becomes unnecessary if ESLint flat config (v9+) is adopted:
# flat config resolves plugins from the config file's own node_modules only,
# so no hoisting is needed.
public-hoist-pattern[]=*eslint*

# darkreader is imported directly in src/hooks/useDarkReader.tsx but is NOT a
# direct dependency of this repo. It is a runtime external provided by
# @zextras/carbonio-shell-ui at runtime (the shell bundles and exposes it).
# The hoist is needed only so static analysis tools (ESLint import/no-unresolved,
# TypeScript) can resolve the module during development. Do not add darkreader
# as a devDependency — that would misrepresent ownership of the package.
public-hoist-pattern[]=darkreader
